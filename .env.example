# Resend API key. Required for the /contact form to actually send email.
# Get one at https://resend.com/api-keys
RESEND_API_KEY=

# Optional: override who the contact form emails land from / to.
# FROM must be a verified sender domain/address in Resend.
CONTACT_FROM_EMAIL="BekerDev <noreply@beker.dev>"
CONTACT_TO_EMAIL="hello@beker.dev"
